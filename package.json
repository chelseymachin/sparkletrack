{
  "name": "sparkletrack",
  "version": "1.0.2",
  "description": "An issue tracker for hobby developers",
  "main": "electron/main.js",
  "type": "module",
  "author": {
    "name": "Chelsey Machin",
    "email": "chelseymachin@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dev": "npm run dev --workspace=packages/frontend",
    "dev:electron": "concurrently \"npm run dev --workspace=packages/frontend\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run build --workspace=packages/frontend",
    "build:electron": "npm run build && electron-builder",
    "dist": "npm run build:electron"
  },
  "workspaces": [
    "packages/frontend"
  ],
  "build": {
    "appId": "com.sparkletrack.app",
    "productName": "SparkleTrack",
    "icon": "electron/icons/icon",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "packages/frontend/dist/**/*",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!**/*.map"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "electron/icons/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "electron/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "electron/icons/icon.png",
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  }
}
